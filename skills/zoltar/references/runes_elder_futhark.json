     1|[
     2|  {"id": 1, "name": "Fehu", "name_alt": "Feoh", "meaning": "Cattle/Wealth", "aett": "Freyja", "upright": "Abundance, financial gain, success, new beginnings, creative energy, mobile power", "reversed": "Loss of wealth, financial setback, greed, poverty mindset, lack of generosity, stagnation", "can_reverse": true, "rune_poem": "Wealth is a comfort to all men; yet must every man bestow it freely, if he would gain honour in the sight of the Lord."},
     3|  {"id": 2, "name": "Uruz", "name_alt": "Ur", "meaning": "Aurochs/Strength", "aett": "Freyja", "upright": "Physical strength, vitality, health, raw power, endurance, freedom, manifesting energy", "reversed": "Weakness, illness, lack of adaptation, missed opportunity, force misapplied, loss of vitality", "can_reverse": true, "rune_poem": "The aurochs is proud and has great horns; a very fierce beast, it fights with its horns, a great rover of the moors, a bold creature."},
     4|  {"id": 3, "name": "Thurisaz", "name_alt": "Thorn", "meaning": "Giant/Thorn", "aett": "Freyja", "upright": "Reactive force, directed chaos, protection, defensive power, catalyst for change, thorn of awareness", "reversed": "Vulnerability, betrayal, compulsion, powerless against forces, defenselessness, danger", "can_reverse": true, "rune_poem": "Thorn is exceedingly sharp, an evil thing for any thane to touch; it is exceedingly hard, measuring about an inch."},
     5|  {"id": 4, "name": "Ansuz", "name_alt": "Os", "meaning": "God/Mouth", "aett": "Freyja", "upright": "Divine inspiration, wisdom, communication, eloquence, ancestral knowledge, Odin's breath, revelation", "reversed": "Miscommunication, misunderstanding, lack of inspiration, manipulation, mental block, lack of clarity", "can_reverse": true, "rune_poem": "The mouth is the source of all speech, a comfort to the wise, and a blessing to every man."},
     6|  {"id": 5, "name": "Raidho", "name_alt": "Rad", "meaning": "Journey/Ride", "aett": "Freyja", "upright": "Journey, travel, movement, rhythm, right action, cosmic order, ritual, spiritual quest, progress", "reversed": "Delays, wrong direction, poor timing, misaligned action, stagnation, broken rhythm", "can_reverse": true, "rune_poem": "Riding in the hall is easy for a warrior; it is harder to sit on a swift horse."},
     7|  {"id": 6, "name": "Kenaz", "name_alt": "Cen", "meaning": "Torch/Knowledge", "aett": "Freyja", "upright": "Knowledge, illumination, creativity, inner guidance, controlled fire, craft skill, opening", "reversed": "Darkness, lack of vision, false knowledge, extinguished creativity, ignorance, stagnation", "can_reverse": true, "rune_poem": "The torch is known to all by its pale bright flame; it always burns where princes sit within."},
     8|  {"id": 7, "name": "Gebo", "name_alt": "Gyfu", "meaning": "Gift/Generosity", "aett": "Freyja", "upright": "Generosity, partnership, exchange, sacred mark, balance in giving and receiving, marriage, magical exchange", "reversed": null, "can_reverse": false, "rune_poem": "Generosity brings credit and honour, which support one's dignity; it furnishes help and subsistence for all broken men."},
     9|  {"id": 8, "name": "Wunjo", "name_alt": "Wyn", "meaning": "Joy/Glory", "aett": "Freyja", "upright": "Joy, pleasure, harmony, wish fulfillment, belonging, comfort, success, happiness, fellowship", "reversed": "Sorrow, grief, alienation, lack of harmony, missed wish, strife, isolation, dissatisfaction", "can_reverse": true, "rune_poem": "Joy is needed by all the human race; it drives away sorrow, increases glory, and lifts the spirit."},
    10|  {"id": 9, "name": "Hagalaz", "name_alt": "Haegl", "meaning": "Hail/Destruction", "aett": "Heimdall", "upright": "Disruption, elemental forces, hail, necessary destruction, crisis as catalyst, the seed of change, testing", "reversed": null, "can_reverse": false, "rune_poem": "Hail is the whitest of grain; it is whirled from the vault of heaven and is pelted by the wind."},
    11|  {"id": 10, "name": "Nauthiz", "name_alt": "Need", "meaning": "Need/Constraint", "aett": "Heimdall", "upright": "Constraint, necessity, hardship, resistance, need-fire, creative limitation, endurance, spiritual trial", "reversed": "Freedom from constraint, release, impulse, heedlessness, recklessness, ignoring necessity", "can_reverse": true, "rune_poem": "Need is oppressive to the heart; yet often it proves a source of help and salvation to the children of men."},
    12|  {"id": 11, "name": "Isa", "name_alt": "Is", "meaning": "Ice/Stillness", "aett": "Heimdall", "upright": "Ice, stillness, stagnation, pause, concentration, ego, frozen potential, waiting, contraction", "reversed": null, "can_reverse": false, "rune_poem": "Ice is very cold and immeasurably slippery; it glistens as clear as glass and is like gems; it is a floor wrought by frost, fair to look upon."},
    13|  {"id": 12, "name": "Jera", "name_alt": "Ger", "meaning": "Harvest/Year", "aett": "Heimdall", "upright": "Harvest, reward, cycles, natural law, patience, fruition, seasonal turning, gradual development, agriculture", "reversed": null, "can_reverse": false, "rune_poem": "Harvest is a joy to men, when God, the holy King of Heaven, suffers the earth to bring forth shining fruits for rich and poor alike."},
    14|  {"id": 13, "name": "Eihwaz", "name_alt": "Eoh", "meaning": "Yew/Defense", "aett": "Heimdall", "upright": "Defense, endurance, transformation, yew tree, life and death, initiation, perseverance, the axis mundi", "reversed": null, "can_reverse": false, "rune_poem": "The yew is a tree with rough bark, hard and fast in the earth, supported by its roots, a guardian of flame and a joy upon the land."},
    15|  {"id": 14, "name": "Perthro", "name_alt": "Peorth", "meaning": "Fate/Mystery", "aett": "Heimdall", "upright": "Mystery, fate, chance, divination, hidden things, the well of destiny, secret knowledge, feminine power", "reversed": "Stagnation, emptiness, lack of opportunity, dullness, denial of mystery, disillusion", "can_reverse": true, "rune_poem": "Gaming is always play and laughter, where boastful men sit in the beer-hall, cheerfully together."},
    16|  {"id": 15, "name": "Algiz", "name_alt": "Elk", "meaning": "Protection/Elk", "aett": "Heimdall", "upright": "Protection, defense, warding, connection to gods, sanctuary, shielding force, spiritual aspiration, guardian", "reversed": "Vulnerability, hidden danger, weakness, false protection, exposure, taboo", "can_reverse": true, "rune_poem": "The elk-sedge is mostly to be found in marshes; it grows in the water and makes a ghastly wound, covering with blood every warrior who touches it."},
    17|  {"id": 16, "name": "Sowilo", "name_alt": "Sigel", "meaning": "Sun/Victory", "aett": "Heimdall", "upright": "Sun, vitality, success, wholeness, solar power, health, victory, confidence, lightning flash of inspiration", "reversed": null, "can_reverse": false, "rune_poem": "The sun is ever a joy to seafarers, when they journey away over the great ocean."},
    18|  {"id": 17, "name": "Tiwaz", "name_alt": "Tir", "meaning": "Victory/Tyr", "aett": "Tyr", "upright": "Victory, honor, justice, sacrifice, the god Tyr, self-sacrifice, rationality, law, warrior's path", "reversed": "Injustice, lack of faith, imbalance, defeat, poor analysis, lack of honor", "can_reverse": true, "rune_poem": "Tir is a guiding sign; it keeps troth well with warriors; it is ever on course over the night of vapors."},
    19|  {"id": 18, "name": "Berkano", "name_alt": "Beorc", "meaning": "Birch/Growth", "aett": "Tyr", "upright": "Birth, fertility, growth, new beginnings, nurturing, motherhood, renewal, healing, feminine power", "reversed": "Problems with growth, infertility, stagnation, family problems, failed new start, anxiety", "can_reverse": true, "rune_poem": "The birch is fruit-bearing without fruit; it bears instead shoots without seed; its branches are glorious, adorned with leaves, heavy in the forest."},
    20|  {"id": 19, "name": "Ehwaz", "name_alt": "Eh", "meaning": "Horse/Movement", "aett": "Tyr", "upright": "Movement, progress, trust, partnership, teamwork, horse and rider, swift change, loyal companionship", "reversed": "Mistrust, stagnation, blocked movement, discord, lack of cooperation, frustration", "can_reverse": true, "rune_poem": "The horse is a joy to princes in the presence of warriors; a steed in the pride of its hooves, when concerning it with wealth."},
    21|  {"id": 20, "name": "Mannaz", "name_alt": "Man", "meaning": "Humanity/Self", "aett": "Tyr", "upright": "Humanity, self-awareness, community, intelligence, divine structure, the rational mind, cooperation", "reversed": "Self-delusion, blindness, isolation, despair, lack of cooperation, manipulation", "can_reverse": true, "rune_poem": "The joyous man is dear to his kinsmen; yet every man must fail his fellows, since the Lord by his decree will commit the vile carrion to the earth."},
    22|  {"id": 21, "name": "Laguz", "name_alt": "Lagu", "meaning": "Water/Flow", "aett": "Tyr", "upright": "Water, intuition, flow, emotion, dreams, the unconscious, psychic ability, going with the current", "reversed": "Fear, illusion, confusion, lack of flow, going against the current, emotional turmoil", "can_reverse": true, "rune_poem": "The ocean seems interminable to men, if they must venture on the rolling bark, and the sea waves terrify them."},
    23|  {"id": 22, "name": "Ingwaz", "name_alt": "Ing", "meaning": "Fertility/Ing", "aett": "Tyr", "upright": "Fertility, new beginnings, potential, the god Ing, completion, gestation, family, internal growth", "reversed": null, "can_reverse": false, "rune_poem": "Ing was first seen by men among the East Danes, till he departed eastward over the sea; his chariot followed after."},
    24|  {"id": 23, "name": "Dagaz", "name_alt": "Daeg", "meaning": "Dawn/Breakthrough", "aett": "Tyr", "upright": "Dawn, breakthrough, awakening, transformation, daylight, balance of opposites, enlightenment, paradigm shift", "reversed": null, "can_reverse": false, "rune_poem": "Day is the Lord's messenger, dear to men, the great god's light, mirth and hope to rich and poor, useful to all."},
    25|  {"id": 24, "name": "Othala", "name_alt": "Ethel", "meaning": "Heritage/Homeland", "aett": "Tyr", "upright": "Heritage, ancestral property, homeland, spiritual estate, genetic legacy, inheritance, belonging, freedom", "reversed": "Lack of tradition, rootlessness, homelessness, loss of heritage, poverty, disconnection from ancestors", "can_reverse": true, "rune_poem": "An estate is very dear to every man, if he can enjoy there in his house whatever is right and proper in prosperity."}
    26|]
